	<string>This app may send you notifications about game achievements and high scores.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>This app may use local network for Game Center features.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_gamecenter._tcp</string>
	</array>

{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/sfx/**",
        "headers": [
          {
            "key": "Accept-Ranges",
            "value": "bytes"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/music/**",
        "headers": [
          {
            "key": "Accept-Ranges",
            "value": "bytes"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}



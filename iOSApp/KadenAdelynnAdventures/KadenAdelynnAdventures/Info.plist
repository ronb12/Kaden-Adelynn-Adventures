	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.kadenadelynn.adventures</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>kadenadelynnadventures</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>gamecenter</string>
	</array>
